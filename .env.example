# =============================================================================
# TrustVend Nigeria — Environment variables
# Copy this file to `.env.local` and fill in the values.
# =============================================================================

# --- Auth (NextAuth) ---------------------------------------------------------
NEXTAUTH_SECRET=replace-me-with-a-32-byte-random-string
NEXTAUTH_URL=http://localhost:3000

# --- Image hosts allowed by next/image ---------------------------------------
NEXT_PUBLIC_IMAGE_HOSTS=instagram.com,cdninstagram.com,fbcdn.net

# --- Demo creds toggle (shows the demo accounts in the auth dialog) ----------
NEXT_PUBLIC_SHOW_DEMO_CREDS=true

# =============================================================================
# Convex (self-hosted BaaS)
# Backend:  https://github.com/get-convex/convex-backend
# Docs:     https://docs.convex.dev/self-hosted
# =============================================================================

# --- Browser-facing URL (used by ConvexProvider in src/components/providers.tsx) ---
NEXT_PUBLIC_CONVEX_URL=http://localhost:3210

# --- CLI / server-side: backend URL (used by `npx convex dev` / `npx convex deploy`) ---
CONVEX_SELF_HOSTED_URL=http://localhost:3210

# --- CLI / server-side: admin key (used by `npx convex dev` / `npx convex deploy`) ---
# Generated inside the backend container with:
#     docker compose exec backend ./generate_admin_key.sh
CONVEX_SELF_HOSTED_ADMIN_KEY=

# =============================================================================
# Convex backend env vars (set these on the SERVER hosting Convex, NOT in this
# Next.js app's .env.local). They are listed here for reference.
#
#   NEXT_PUBLIC_DEPLOYMENT_URL  → URL the dashboard uses to find the backend API
#   CONVEX_CLOUD_ORIGIN         → Public URL the client/CLI uses to reach the
#                                  backend's HTTP API and WebSocket.
#   CONVEX_SITE_ORIGIN          → Public URL for HTTP actions (port 3211).
#
# --- One-time admin bootstrap -----------------------------------------------
# Set this to your admin email on the Convex backend (NOT here in the
# Next.js app) when bootstrapping a fresh deployment. The FIRST account
# registered with this email is auto-promoted to ADMIN role. Remove the
# env var from the backend once your admin account exists.
#
#   BOOTSTRAP_ADMIN_EMAIL=you@example.com
# =============================================================================
